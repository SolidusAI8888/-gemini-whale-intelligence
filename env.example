# Required by SEC fair-access policy. Format: AppName contact@email.com
SEC_USER_AGENT=GeminiWhaleIntelligence your_email@example.com

# Runtime
DATABASE_PATH=data/whale.db
LOOKBACK_DAYS=3
MAX_COMPANIES=0
MIN_OPPORTUNITY_SCORE=55
SEND_EMAIL=false
DRY_RUN=true

# Optional AI analysis
ENABLE_GEMINI=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# Email via SendGrid
SENDGRID_API_KEY=
EMAIL_FROM=reports@example.com
EMAIL_TO=your_email@example.com

# GitHub Actions artifact/report behavior
REPORT_DIR=data/reports
