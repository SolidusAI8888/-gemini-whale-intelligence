SEC_USER_AGENT=WhaleIntelligenceGemini your_email@example.com
DATABASE_PATH=data/whale.db
REPORT_DIR=data/reports
LOOKBACK_DAYS=200
SCAN_START_DATE=2026-01-01
3
MAX_COMPANIES=0
MIN_OPPORTUNITY_SCORE=55

SEND_EMAIL=false
DRY_RUN=true
# Email provider: sendgrid or smtp. Use smtp for iCloud Mail.
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=
EMAIL_FROM=
EMAIL_TO=

# SMTP / iCloud Mail. For iCloud use smtp.mail.me.com:587 and an Apple app-specific password.
SMTP_HOST=smtp.mail.me.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_STARTTLS=true
SMTP_FROM_NAME=Gemini Whale Intelligence

ENABLE_GEMINI=true
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# Political whale module
ENABLE_POLITICAL=true
ENABLE_POLITICAL_TRADES=true
POLITICAL_PROVIDER=official_house
POLITICAL_MAX_FILINGS=300
FMP_API_KEY=
# Free/default mode: keep FMP congressional endpoints disabled because House/Senate FMP endpoints are often paid/restricted.
FMP_CONGRESSIONAL_ENABLED=false
FMP_MAX_PAGES=5
FMP_PAGE_LIMIT=100

# Political module scope: core|all|both. Use all/both to debug Pelosi/Congress trades outside S&P500/Nasdaq100.
POLITICAL_UNIVERSE_SCOPE=core
POLITICAL_UNIVERSE_SCOPE=all
FMP_HOUSE_ENDPOINTS=house-latest,house-trades
FMP_SENATE_ENDPOINTS=senate-latest,senate-trades
POLITICAL_WATCH_NAMES=Pelosi,Trump

# V10 free market-data connectors
ENABLE_MARKET_DATA=true
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=
MARKET_DATA_MAX_SYMBOLS=25
ALPHA_DAILY_ENABLED=true
ALPHA_OVERVIEW_ENABLED=true
FINNHUB_BASIC_FINANCIALS_ENABLED=true
FINNHUB_NEWS_ENABLED=true
FINNHUB_INSIDER_ENABLED=true

# OGE Executive Branch module (President / Cabinet). Use official OGE or OGE-hosted PDF URLs.
ENABLE_OGE_EXECUTIVE_TRADES=true
OGE_TRUMP_REPORT_URLS=
# Semicolon-separated entries: Name|Title|PDF_URL|Agency
OGE_CABINET_REPORTS=
OGE_MAX_REPORTS=20

# OGE auto-discovery watcher (optional; manual PDF URLs remain most reliable)
ENABLE_OGE_AUTO_DISCOVERY=true
OGE_DISCOVERY_URLS=https://www.oge.gov/web/oge.nsf/Officials%20Individual%20Disclosures%20Search%20Collection?OpenForm
OGE_DISCOVERY_WATCHLIST=Donald J. Trump,JD Vance,Marco Rubio,Scott Bessent,Pete Hegseth,Pamela Bondi,Doug Burgum,Brooke Rollins,Howard Lutnick,Chris Wright,Doug Collins,Kristi Noem,Tulsi Gabbard,John Ratcliffe
OGE_DISCOVERY_MAX_LINKS=50

# V19 Cabinet OGE asset/disclosure radar
OGE_SEED_CABINET_REPORTS_ENABLED=true
ENABLE_OGE_ASSET_DISCLOSURES=true
# Optional extra public OGE PDFs; semicolon-separated, format:
# Name|Position|PDF_URL|Agency|ReportType
# ReportType examples: OGE_278_T, OGE_278e, OGE_ETHICS_AGREEMENT, OGE_DIVESTITURE
OGE_SEED_CABINET_REPORTS=

# V27: SEC 13F institutional whale radar (quarterly holdings, not real-time trades)
ENABLE_INSTITUTIONAL_13F=true
INSTITUTIONAL_13F_MAX_MANAGERS=20
INSTITUTIONAL_13F_FILINGS_PER_MANAGER=2
INSTITUTIONAL_13F_MAX_HOLDINGS_PER_FILING=25
# Optional override; format one per line or semicolon-separated:
# Manager Name|CIK|Lead Investor|Style
INSTITUTIONAL_13F_WATCHLIST=
