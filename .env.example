SEC_USER_AGENT=WhaleIntelligenceGemini your_email@example.com
DATABASE_PATH=data/whale.db
REPORT_DIR=data/reports
LOOKBACK_DAYS=3
MAX_COMPANIES=0
MIN_OPPORTUNITY_SCORE=55

SEND_EMAIL=false
DRY_RUN=true
SENDGRID_API_KEY=
EMAIL_FROM=
EMAIL_TO=

ENABLE_GEMINI=true
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# Political whale module
ENABLE_POLITICAL_TRADES=true
POLITICAL_PROVIDER=official_house
POLITICAL_MAX_FILINGS=300
FMP_API_KEY=
# Free/default mode: keep FMP congressional endpoints disabled because House/Senate FMP endpoints are often paid/restricted.
FMP_CONGRESSIONAL_ENABLED=false
FMP_MAX_PAGES=5
FMP_PAGE_LIMIT=100

# Political module scope: core|all|both. Use all/both to debug Pelosi/Congress trades outside S&P500/Nasdaq100.
POLITICAL_UNIVERSE_SCOPE=core
POLITICAL_UNIVERSE_SCOPE=all
FMP_HOUSE_ENDPOINTS=house-latest,house-trades
FMP_SENATE_ENDPOINTS=senate-latest,senate-trades
POLITICAL_WATCH_NAMES=Pelosi,Trump

# V10 free market-data connectors
ENABLE_MARKET_DATA=true
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=
MARKET_DATA_MAX_SYMBOLS=25
ALPHA_DAILY_ENABLED=true
ALPHA_OVERVIEW_ENABLED=true
FINNHUB_BASIC_FINANCIALS_ENABLED=true
FINNHUB_NEWS_ENABLED=true
FINNHUB_INSIDER_ENABLED=true
